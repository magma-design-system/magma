{
  "npmScope": "maggioli-design-system",
  "implicitDependencies": {
    "workspace.json": "*",
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    },
    "nx.json": "*"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/workspace/tasks-runners/default",
      "options": {
        "cacheableOperations": [
          "build",
          "test",
          "lint",
          "package"
        ]
      }
    }
  },
  "projects": {
    "design-tokens": {
      "implicitDependencies": []
    },
    "docs": {
      "tags": ["type:app"],
      "implicitDependencies": ["styles", "icons"]
    },
    "font-icons-cli": {
      "tags": ["type:lib"],
      "implicitDependencies": ["icons-svg"]
    },
    "identity": {
      "tags": ["type:lib"],
      "implicitDependencies": []
    },
    "icons": {
      "tags": ["type:lib"],
      "implicitDependencies": ["font-icons-cli"]
    },
    "icons-svg": {
      "tags": ["type:lib"],
      "implicitDependencies": []
    },
    "react": {
      "tags": ["type:lib"],
      "implicitDependencies": ["styles", "icons"]
    },
    "styles": {
      "tags": ["type:lib"],
      "implicitDependencies": ["design-tokens"]
    }
  },
  "affected": {
    "defaultBase": "dev"
  }
}
