{
  "sans": {
    "family": "-apple-system, BlinkMacSystemFont, San Francisco, Roboto, Segoe UI, Helvetica Neue, sans-serif",
    "styles": {
      "h1" : {
        "default": {
          "font-size": "42px",
          "line-height": "60px",
          "font-weight": "700"
        },
        "tablet": {
          "line-height": "65px"
        },
        "desktop": {
          "line-height": "70px"
        }
      },
      "h2" : {
        "default": {
          "font-size": "33px",
