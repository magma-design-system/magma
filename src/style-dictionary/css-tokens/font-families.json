          "font-weight": "600"
        },
        "tablet": {
          "line-height": "30px"
        }
      },
      "h6" : {
        "default": {
          "font-size": "16px",
          "font-variant-caps": "all-small-caps",
          "font-weight": "500",
          "line-height": "25px"
