{
  "extends": [
    "../../.eslintrc.json"
  ],
  "parser": "@babel/eslint-parser",
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    },
    "ecmaVersion": 2018,
    "requireConfigFile": false,
    "sourceType": "module"
  },
  "env": {
    "browser": true,
    "es6": true,
    "jest": true
  },
  "globals": {
    "Atomics": "readonly",
    "SharedArrayBuffer": "readonly"
  },
  "settings": {
    "react": {
      "pragma": "React",
      "version": "17.0.2"
    }
  },
  "plugins": [
    "react",
    "import"
  ],
  "overrides": [
    {
      "files": [
        "*.jsx"
      ],
      "rules": {
        "react/no-find-dom-node": "warn",
        "react/no-string-refs": "warn",
        "react/jsx-uses-vars": "warn",
        "react/jsx-uses-react": "warn",
        "react/value-keyword-case": "off",
        "react/prefer-stateless-function": "warn",
        "react/prop-types": [
          "error",
          {
            "ignore": [
              "children"
            ]
          }
        ]
      }
    }
  ]
}
