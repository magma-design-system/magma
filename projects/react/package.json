{
    "name": "@maggioli-design-system/react",
    "version": "0.17.0",
    "description": "Maggioli Design System è uno strumento nato per condividere una unica visione di progettazione condivisa tra tutti gli esperti di dominio aziendali. Ciò permette di offrire una UX unica, condivisa tra i prodotti che saranno coerenti allo stile dell’azienda.",
    "scripts": {
        "build": "webpack --config webpack.config.js",
        "build-storybook": "build-storybook",
        "deploy-storybook": "storybook-to-ghpages",
        "lint": "npm run lint-js && npm run lint-sass",
        "lint-js": "eslint src/**/*.{js,jsx} --fix",
        "lint-sass": "stylelint --config ../../.stylelintrc.json 'src/**/*.scss' --fix",
        "start": "start-storybook -p 7177",
        "start-debug": "start-storybook --debug-webpack -p 7177"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged",
            "pre-push": ""
        }
    },
    "lint-staged": {
        "src/**/*.{js,jsx}": [
            "npm run lint-js"
        ],
        "src/**/*.{scss}": [
            "npm run lint-sass"
        ]
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ],
    "main": "dist/bundle.min.js",
    "files": [
        "/import-aliases.js",
        "/dist/**/*"
    ],
    "repository": {
        "type": "git",
        "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
    },
    "bugs": {
