{
  "skipLibCheck": true,
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "declaration": false,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "lib": [
      "es2017"
    ],
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2017",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": false,
    "strict": false,
    "types": ["node"]
  },
  "include": [
    "scripts"
  ],
  "exclude": [
    "dist",
    "node_modules",
  ]
}
