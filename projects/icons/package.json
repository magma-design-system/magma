{
  "name": "@maggioli-design-system/icons",
  "version": "1.91.0",
  "description": "Maggioli Design System Icons is an icon font package based on Google Material Design Icons and Material Design Icons community icons.",
  "main": "./dist/mgg-icons.css",
  "files": [
    "/index.ts",
    "/dist/",
    "/resources/*.json"
  ],
  "scripts": {
    "build": "tsx ./scripts/font-icons.ts dictionary.json -- --website",
    "postbuild": "tsx ./scripts/setup-package-font.ts",
    "clean": "tsx scripts/clean.ts",
    "prebuild": "tsx ./scripts/clean.ts",
    "start": "tsx ./scripts/font-icons.ts"
  },
  "dependencies": {
    "@maggioli-design-system/svg-icons": "4.2.0",
    "@material-icons/svg": "1.0.33",
    "@mdi/svg": "7.4.47",
    "material-design-icons-updated": "7.0.0"
  },
  "devDependencies": {
    "svgtofont": "3.17.4"
  },
