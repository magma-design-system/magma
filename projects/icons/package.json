{
  "name": "@maggioli-design-system/icons",
  "version": "1.37.0",
  "description": "Maggioli Design System Icons is an icon font package based on Google Material Design Icons and Material Design Icons community icons.",
  "main": "./dist/mgg-icons.css",
  "files": [
    "/dist/*",
    "/resources/*.json"
  ],
  "scripts": {
    "build": "node ./lib/font-icons.js dictionary.json -- --website",
    "postbuild": "node ./tools/setup-package-font.js",
    "clean": "rm -rf ./dist",
    "prebuild": "npm run clean",
    "start": "./bin/font-icons.js",
    "test": "jest --coverage",
    "test-build": "npm run clean && npm start test.json svg -- --website"
  },
  "dependencies": {
    "@maggioli-design-system/svg-icons": "^2.6.0",
    "@mdi/svg": "^6.5.95",
    "material-design-icons-updated": "^7.0.0"
  },
  "devDependencies": {
    "@types/jest": "^26.0.22",
    "chalk": "^4.1.1",
    "fs-extra": "^9.1.0",
    "jest": "^26.6.3",
    "svgtofont": "^3.14.0",
    "ts-jest": "^26.5.4",
    "ts-node": "^9.1.1",
    "typescript": "^4.1.3"
  },
  "keywords": [
    "font",
    "icons",
    "svg"
  ],
  "author": {
    "name": "Vittorio Vittori",
    "email": "vittorio.vittori@maggioli.it",
    "url": "http://vit.to"
  },
