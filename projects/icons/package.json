{
  "name": "@maggioli-design-system/icons",
  "version": "1.40.0",
  "description": "Maggioli Design System Icons is an icon font package based on Google Material Design Icons and Material Design Icons community icons.",
  "main": "./dist/mgg-icons.css",
  "files": [
    "/dist/*",
    "/resources/*.json"
  ],
  "scripts": {
    "build": "npx ts-node --skipProject ./scripts/font-icons.ts dictionary.json -- --website",
    "postbuild": "npx ts-node --skipProject ./scripts/setup-package-font.ts",
    "clean": "npx ts-node --skipProject scripts/clean.ts",
    "prebuild": "npx ts-node --skipProject ./scripts/clean.ts",
    "start": "npx ts-node --skipProject ./scripts/font-icons.ts"
  },
  "dependencies": {
    "@maggioli-design-system/svg-icons": "^2.7.0",
    "@mdi/svg": "^6.7.96",
    "material-design-icons-updated": "^7.0.0"
  },
  "devDependencies": {
    "chalk": "^4.1.1",
    "fs-extra": "^9.1.0",
    "svgtofont": "3.17.4",
    "typescript": "^4.1.3"
  },
  "keywords": [
    "font",
    "icons",
    "svg"
  ],
  "author": {
    "name": "Vittorio Vittori",
    "email": "vittorio.vittori@maggioli.it",
    "url": "http://vit.to"
  },
  "contributors": [
