{
  "name": "@maggioli-design-system/styles",
  "version": "3.8.4",
  "description": "This module contains SCSS and CSS styles used by Maggioli Design System, it also makes available a Tailwind config based on Maggioli design tokens.",
  "main": "css/styles.min.css",
  "scripts": {
    "build": "npm run clean && npm run config && npm run sass && npm run copy:sass && npm run copy:tailwind",
    "clean": "rm -rf dist || true && mkdir -p dist/css dist/scss dist/tailwind",
    "config": "cp ../../node_modules/@maggioli-design-system/design-tokens/dist/scss/config.scss ./scss",
    "copy:sass": "cp -rf scss dist",
    "copy:tailwind": "cp -rf tailwind dist",
    "sass": "npm run sass:styles && npm run sass:styles:min && npm run sass:base && npm run sass:base:min && npm run sass:colors && npm run sass:colors:min && npm run sass:palette && npm run sass:palette:min && npm run sass:typography && npm run sass:typography:min",
    "sass:base": "sass ./scss/export/base.scss ./dist/css/base.css --style=expanded --load-path=../../node_modules",
    "sass:base:min": "sass ./scss/export/base.scss ./dist/css/base.min.css --style=compressed --no-source-map --load-path=../../node_modules",
    "sass:colors": "sass ./scss/export/colors.scss ./dist/css/colors.css --style=expanded --load-path=../../node_modules",
    "sass:colors:min": "sass ./scss/export/colors.scss ./dist/css/colors.min.css --style=compressed --no-source-map --load-path=../../node_modules",
    "sass:palette": "sass ./scss/export/color-palette.scss ./dist/css/color-palette.css --style=expanded --load-path=../../node_modules",
    "sass:palette:min": "sass ./scss/export/color-palette.scss ./dist/css/color-palette.min.css --style=compressed --no-source-map --load-path=../../node_modules",
    "sass:styles": "sass ./scss/export/styles.scss ./dist/css/styles.css --style=expanded --load-path=../../node_modules",
    "sass:styles:min": "sass ./scss/export/styles.scss ./dist/css/styles.min.css --style=compressed --no-source-map --load-path=../../node_modules",
    "sass:typography": "sass ./scss/export/typography.scss ./dist/css/typography.css --style=expanded --load-path=../../node_modules",
    "sass:typography:min": "sass ./scss/export/typography.scss ./dist/css/typography.min.css --style=compressed --no-source-map --load-path=../../node_modules"
  },
  "files": [
    "/postcss.config.js",
    "/tailwind.config.js",
    "/dist/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
  },
  "keywords": [
    "sass",
    "scss",
    "css",
    "tailwindcss"
  ],
  "author": "Vittorio Vittori",
  "contributors": [
    {
      "name": "Vittorio Vittori",
      "email": "vittorio.vittori@maggioli.it",
      "role": "UX UI Designer"
    }
  ],
  "license": "ISC",
  "dependencies": {
    "@maggioli-design-system/design-tokens": "^4.0.2",
    "normalize.css": "^8.0.1",
    "typeface-karla": "1.1.13",
    "typeface-roboto": "1.1.13"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "0.2.1",
    "autoprefixer": "^10.3.1",
    "postcss": "^8.3.5",
    "postcss-import": "14.0.2",
    "sass": "^1.35.1",
    "sass-extract": "^2.1.0",
    "sass-loader": "^12.1.0",
    "tailwindcss": "^2.2.4",
    "tailwindcss-multi-column": "^1.0.2"
  }
}
