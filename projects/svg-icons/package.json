{
  "name": "@maggioli-design-system/svg-icons",
  "version": "4.5.0",
  "description": "Maggioli Design System Icons is an icon font package based on Google Material Design Icons and Material Design Icons community icons.",
  "files": ["dist"],
  "scripts": {
    "build": "npm run clean && npm run dictionary && npm run svg",
    "svg": "svgo -f ./svg -o ./dist/svg",
    "clean": "tsx scripts/clean.ts",
    "dictionary": "tsx scripts/iconsauce.ts",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "fast-glob": "3.3.2",
    "svgo": "3.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magma-design-system/magma.git",
    "directory": "projects/svg-icons"
  },
  "bugs": {
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system/-/issues"
  },
  "keywords": [
    "icons",
    "svg"
  ],
  "author": {
    "name": "Gioele Masini",
    "role": "Software Engineer"
  },
  "contributors": [
    {
      "name": "Gioele Masini",
      "role": "Software Engineer"
    },
    {
      "name": "Vittorio Vittori",
      "email": "vittorio.vittori@maggioli.it",
      "role": "UX UI Designer"
    }
  ],
  "license": "ISC"
}
