  "files": [
    "/build/fonts/**/*.ttf",
    "/build/fonts/**/*.woff",
    "/build/fonts/**/*.woff2",
    "/build/fonts/**/*.eot",
    "/build/fonts/**/*.svg",
    "/build/fonts/**/*.scss",
    "/build/fonts/**/*.css",
    "/build/fonts/**/*.html",
    "/build/fonts/**/*.js",
    "/build/fonts/**/*.ts",
    "/src/*.json"
