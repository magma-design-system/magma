{
    "name": "@maggioli-design-system/doc",
    "version": "0.13.0",
    "description": "Maggioli Design System è uno strumento nato per condividere una unica visione di progettazione condivisa tra tutti gli esperti di dominio aziendali. Ciò permette di offrire una UX unica, condivisa tra i prodotti che saranno coerenti allo stile dell’azienda.",
    "private": true,
    "scripts": {
        "start": "npm run clean && npm run develop",
        "build": "gatsby build",
        "clean": "gatsby clean",
        "serve": "gatsby serve -o -p 3898",
        "develop": "gatsby develop -H 0.0.0.0 -p 3898 -o",
        "lint": "npm run lint:js && npm run lint:sass",
        "lint:js": "eslint src/**/*.{js,jsx} --fix",
        "lint:sass": "stylelint --config .stylelintrc.json 'src/**/*.scss' --fix",
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged",
            "pre-push": ""
        }
    },
    "lint-staged": {
        "src/**/*.{js,jsx}": [
            "npm run lint:js"
        ],
        "src/**/*.{scss}": [
            "npm run lint:sass"
        ]
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ],
