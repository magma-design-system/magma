{
    "name": "@maggioli-design-system/docs",
    "version": "0.13.2",
    "description": "Progetto della documentazione del Design System del Gruppo Maggioli.",
    "private": true,
    "scripts": {
        "start": "npm run clean && npm run develop",
        "build": "gatsby build",
        "clean": "gatsby clean",
        "serve": "gatsby serve -o -p 3898",
        "develop": "gatsby develop -H 0.0.0.0 -p 3898 -o",
        "lint": "npm run lint-js && npm run lint-sass",
        "lint-js": "eslint src/**/*.{js,jsx} --fix",
        "lint-sass": "stylelint --config .stylelintrc.json 'src/**/*.scss' --fix"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged",
            "pre-push": ""
        }
    },
    "lint-staged": {
        "src/**/*.{js,jsx}": [
            "npm run lint-js"
        ],
        "src/**/*.{scss}": [
            "npm run lint-sass"
        ]
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ],
    "repository": {
        "type": "git",
        "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
    },
