  "scripts": {
    "clean": "rm -rf dist || true",
    "start": "./bin/font-icons.js",
    "test": "jest --coverage",
    "test-build": "npm run clean && npm start test.json svg -- --website"
  },
  "dependencies": {
    "@maggioli-design-system/icons-svg": "^2.2.0",
    "@mdi/svg": "^5.9.55",
    "material-design-icons-updated": "^7.0.0"
  },
  "devDependencies": {
    "@types/jest": "^26.0.22",
    "jest": "^26.6.3",
    "svgtofont": "3.12.0",
    "ts-jest": "^26.5.4",
    "ts-node": "^9.1.1",
    "typescript": "^4.1.3"
  }
}
