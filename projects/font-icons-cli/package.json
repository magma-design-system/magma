{
  "name": "@maggioli-design-system/font-icons-cli",
  "version": "1.13.2",
  "description": "Font icons CLI, part of Maggioli Design System, it's used by mgg-icons module to generate the font library from SVG icons.",
  "repository": {
    "type": "git",
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
  },
  "author": {
    "name": "Gioele Masini",
    "email": "gioele.masini@maggioli.it"
  },
  "contributors": [
    {
      "name": "Gioele Masini",
      "email": "gioele.masini@maggioli.it",
      "role": "Software Engineer"
    }
  ],
  "license": "ISC",
  "main": "bin/font-icons.js",
  "files": [
    "/bin/**/*",
    "/lib/**/*"
  ],
  "bin": {
    "font-icons": "bin/font-icons.js"
  },
  "keywords": [
    "font",
    "icons",
    "TTF",
    "EOT",
    "WOFF",
    "WOFF2",
    "SVG"
  ],
  "engines": {
    "node": ">= 10.x.x"
  },
  "bugs": {
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system/-/issues"
