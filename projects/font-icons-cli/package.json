{
  "name": "@maggioli-common/font-icons-cli",
  "version": "1.0.0-RC.2",
  "description": "Font icons CLI, part of Maggioli Design System, it's used by mgg-icons module to generate the font library from SVG icons.",
  "publishConfig": {
    "registry": "http://nexus.maggioli.it:8081/repository/npm/"
  },
  "repository": {
    "type": "git",
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
  },
  "author": {
    "name": "Gioele Masini",
    "email": "gioele.masini@maggioli.it"
  },
  "contributors": [
    {
      "name": "Gioele Masini",
      "email": "gioele.masini@maggioli.it",
      "role": "Author"
    }
  ],
  "license": "ISC",
  "main": "bin/font-icons.js",
  "files": [
    "/bin/**/*",
    "/lib/**/*"
  ],
  "bin": {
    "font-icons": "bin/font-icons.js"
  },
  "keywords": [
    "font",
    "icons",
    "TTF",
    "EOT",
    "WOFF",
    "WOFF2",
    "SVG"
  ],
  "engines": {
    "node": ">= 10.x.x"
  },
  "bugs": {
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system/-/issues"
  },
  "scripts": {
    "clean": "rm -rf dist || true",
    "start": "./bin/font-icons.js",
    "test": "jest --coverage",
    "test:build": "npm run clean && npm start test.json svg"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^5.14.0",
    "@maggioli-common/mgg-icons-svg": "^1.0.0-RC.1",
    "@mdi/svg": "^5.8.55",
    "material-design-icons-updated": "^6.1.0",
    "svgtofont": "^3.4.0",
    "typescript": "^4.1.3"
  },
  "devDependencies": {
    "@types/jest": "^26.0.20",
    "jest": "^26.6.3",
    "ts-jest": "^26.4.4",
    "ts-node": "^9.1.1"
  }
}
