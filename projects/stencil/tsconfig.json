{
  "skipLibCheck": true,
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "baseUrl": ".",
    "declaration": false,
    "experimentalDecorators": true,
    "lib": [
      "dom",
      "es2017"
    ],
    "esModuleInterop": true,
    "jsx": "react",
    "jsxFactory": "h",
    "module": "esnext",
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "target": "es2017",
    "paths": {
      "@common/*": [
        "src/common/*"
      ],
      "@component-dist/*": [
        "dist/collection/components/*"
      ],
      "@component/*": [
        "src/components/*"
      ],
      "@dictionary/*": [
        "src/dictionary/*"
      ],
      "@fixture/*": [
        "src/fixtures/*"
      ],
      "@icon/*": [
        "assets/svg/*"
      ],
      "@interface/*": [
        "src/interface/*"
      ],
      "@placeholder": [
        "https://via.placeholder.com"
      ],
      "@test/*": [
        "src/test/*"
      ],
      "@type/*": [
        "src/type/*"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "scripts",
    "src"
  ],
  "exclude": [
    "dist",
    "loader",
    "node_modules",
    "template",
    "www"
  ]
}
