{
  "name": "@maggioli-design-system/mds-file-preview",
  "version": "1.3.4",
  "description": "mds-file-preview is a web-component from Magma Design System, built with StencilJS, TypeScript, Storybook. It's based on the web-component standard and it's designed to be agnostic from the JavaScirpt framework you are using.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mds-file-preview/mds-file-preview.esm.js",
  "files": [
    "dist/",
    "documentation.json",
    "loader/",
    "readme.md",
    "src/",
    "www/"
  ],
  "scripts": {
    "build": "rm src/components.d.ts || true && stencil build --docs-readme",
    "prepublishOnly": "npm run build",
    "test": "stencil test --spec --e2e"
  },
  "dependencies": {
    "@maggioli-design-system/mds-badge": "2.9.2",
    "@maggioli-design-system/mds-button": "4.17.3",
    "@maggioli-design-system/mds-text": "4.3.5",
    "@maggioli-design-system/styles": "14.2.2",
    "@stencil/core": "4.10.0",
    "filesize": "10.1.0"
  },
