{
  "name": "@maggioli-design-system/mds-list-item",
  "version": "3.5.1",
  "description": "mds-list-item is a web-component from Magma Design System, built with StencilJS, TypeScript, Storybook. It's based on the web-component standard and it's designed to be agnostic from the JavaScirpt framework you are using.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mds-list-item/mds-list-item.esm.js",
  "files": [
    "dist/",
    "documentation.json",
    "loader/",
    "readme.md",
    "src/",
    "www/"
  ],
  "scripts": {
    "build": "rm src/components.d.ts || true && stencil build --docs-readme",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@maggioli-design-system/mds-icon": "^2.5.1",
    "@maggioli-design-system/mds-text": "^3.4.2",
    "@maggioli-design-system/styles": "^11.7.0",
    "@stencil/core": "^4.3.0"
  },
  "config": {
    "publishOnLocalRegistry": true
  },
