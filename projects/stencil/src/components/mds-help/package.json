{
  "name": "@maggioli-design-system/mds-help",
  "version": "1.4.3",
  "description": "mds-help is a web-component from Magma Design System, built with StencilJS, TypeScript, Storybook. It's based on the web-component standard and it's designed to be agnostic from the JavaScirpt framework you are using.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mds-help/mds-help.esm.js",
  "files": [
    "dist/",
    "documentation.json",
    "loader/",
    "readme.md",
    "src/",
    "www/"
  ],
  "scripts": {
    "build": "rm src/components.d.ts || true && stencil build --docs-readme",
    "prepublishOnly": "npm run build",
    "test": "stencil test --spec --e2e"
  },
  "dependencies": {
    "@maggioli-design-system/mds-icon": "2.10.2",
    "@maggioli-design-system/mds-tooltip": "4.3.1",
    "@maggioli-design-system/styles": "14.2.2",
    "@stencil/core": "4.10.0"
  },
  "license": "MIT",
  "author": {
    "name": "Vittorio Vittori",
    "email": "vittorio.vittori@maggioli.it",
    "url": "https://vitto.github.io/vit.to/"
  },
  "contributors": [
    {
      "name": "Vittorio Vittori",
      "email": "vittorio.vittori@maggioli.it",
      "role": "Product Designer"
    }
  ]
}
