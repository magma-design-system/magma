{
  "name": "@maggioli-design-system/mds-policy-ai",
  "version": "1.1.5",
  "description": "mds-policy-ai is a web-component from Magma Design System, built with StencilJS, TypeScript, Storybook. It's based on the web-component standard and it's designed to be agnostic from the JavaScript framework you are using.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mds-policy-ai/mds-policy-ai.esm.js",
  "files": [
    "dist/",
    "documentation.json",
    "loader/",
    "readme.md",
    "src/",
    "www/"
  ],
  "scripts": {
    "build": "rm src/components.d.ts || true && stencil build --docs-readme",
    "prepublishOnly": "npm run build",
    "test": "stencil test --spec --e2e"
  },
  "dependencies": {
    "@maggioli-design-system/mds-banner": "7.3.3",
    "@maggioli-design-system/mds-button": "6.8.2",
    "@maggioli-design-system/mds-chip": "3.8.3",
    "@maggioli-design-system/mds-dropdown": "5.8.3",
    "@maggioli-design-system/mds-help": "1.7.3",
    "@maggioli-design-system/mds-icon": "2.13.3",
    "@maggioli-design-system/mds-text": "4.7.5",
    "@maggioli-design-system/styles": "15.11.0"
  },
  "license": "MIT",
  "author": {
    "name": "Vittorio Vittori",
    "email": "vittorio.vittori@maggioli.it",
    "url": "https://vitto.github.io/vit.to/"
  },
  "contributors": [
    {
      "name": "Vittorio Vittori",
      "email": "vittorio.vittori@maggioli.it",
      "role": "Product Designer"
    }
  ]
}
