{
  "name": "@maggioli-design-system/mds-filter-item",
  "version": "2.3.1",
  "description": "mds-filter-item is a web-component from Magma Design System, built with StencilJS, TypeScript, Storybook. It's based on the web-component standard and it's designed to be agnostic from the JavaScirpt framework you are using.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mds-filter-item/mds-filter-item.esm.js",
  "files": [
    "dist/",
    "documentation.json",
    "loader/",
    "readme.md",
    "src/",
    "www/"
  ],
  "scripts": {
    "build": "rm src/components.d.ts || true && stencil build --docs-readme",
    "prepublishOnly": "npm run build",
    "test": "stencil test --spec --e2e"
