{
  "repo": [
    "https://stylelint.io/user-guide/rules/list",
    "https://github.com/kristerkari/stylelint-scss"
  ],
  "extends": ["../../.stylelintrc.json"],
  "plugins": [
    "stylelint-order"
  ],
  "ignoreFiles": [
    "**/dist/*.css",
    "**/*.js",
    "**/*.jsx",
    "**/*.svg"
  ],
  "rules": {
    "at-rule-name-space-after": null,
    "color-function-notation": null,
    "selector-type-no-unknown": null
  }
}
