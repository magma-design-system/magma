{
  "skipLibCheck": true,
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "declaration": false,
    "experimentalDecorators": true,
    "lib": ["esnext", "dom"],
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": false,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "target": "esnext"
  },
  "include": ["scripts"],
  "exclude": ["node_modules", "src"]
}
