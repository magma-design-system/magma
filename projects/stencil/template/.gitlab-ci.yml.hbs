.base-{{ componentName }}:
  variables:
    COMPONENT: mds-{{ componentName }}

# TEST
{{ componentName }}-publish-test:
  extends: [.base-stencil-publish-test, .base-{{ componentName }}]
  dependencies: [base-stencil-build, base-isolate]

# PUBLISH
{{ componentName }}-publish:
  extends: [.base-stencil-publish, .base-{{ componentName }}]
  dependencies: [base-stencil-build, base-isolate]
  needs: [base-stencil-build, base-isolate, {{ componentName }}-publish-test]

# INSTALL TEST
{{ componentName }}-install-test:
  extends: [.base-stencil-install-test, .base-{{ componentName }}]
  dependencies: [base-stencil-build, base-isolate]
  needs: [base-stencil-build, base-isolate, {{ componentName }}-publish]
