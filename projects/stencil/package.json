{
  "name": "@maggioli-design-system/magma",
  "version": "2.0.0-alpha.1",
  "description": "Magma is Maggioli Design System's web-components library.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mds-components/mds-components.esm.js",
  "exports": {
    ".": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.js"
    },
    "./dist/components/*.js": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./dist/components": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/components/index.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs.js",
      "default": "./loader/index.js"
    },
    "./components/*.js": {
      "types": "./dist/types/components/*.d.ts",
      "import": "./components/*.js"
    },
    "./components": {
      "types": "./dist/types/components.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "loader/",
    "AGENTS.md",
    "agents/"
  ],
  "scripts": {
    "build": "npm run clean && npm run build.icons && stencil build --prerender --docs-readme --docs-json dist/documentation.json && npm run sync.agent-docs",
    "sync.agent-docs": "tsx --tsconfig script.tsconfig.json ./scripts/sync-agent-docs.ts",
    "build.docs": "stencil docs",
    "build.icons": "iconsauce --verbose --config ./.storybook/iconsauce.config.js --output-dictionary ./src/fixtures/icons.json --output-svg ./assets/svg --output-dump-dictionary ./src/fixtures/icons-dictionary.json && npm run sort.icons-dictionary",
    "sort.icons-dictionary": "tsx --tsconfig script.tsconfig.json ./scripts/sort-icons-dictionary.ts",
    "build.no-cache": "stencil build --no-cache",
    "build.watch": "npm run build.icons && stencil build -c stencil.dev.config.ts --dev --watch",
    "build.watch-no-cache": "stencil build --no-cache --watch",
    "clean": "tsx --tsconfig script.tsconfig.json ./scripts/clean.ts",
    "generate": "stencil generate",
    "generate.spec": "tsx --tsconfig script.tsconfig.json ./scripts/generate-spec.ts",
    "generate.usage": "tsx --tsconfig script.tsconfig.json ./scripts/generate-usage.ts",
    "lint": "npm run lint.ts && npm run lint.css",
    "lint:fix": "npm run lint.css --fix && npm run lint.ts --fix",
    "lint.css": "stylelint -c ./stylelint.config.mjs  'src/**/*.css'",
    "lint.ts": "eslint .",
    "start": "npm run storybook.clear-cache && storybook dev -p 6006",
    "storybook.build": "storybook build -o ./dist-storybook",
    "storybook.clear-cache": "tsx --tsconfig script.tsconfig.json ./scripts/clean-storybook.ts",
    "storybook.start": "npm run storybook.clear-cache && npm run build.icons && storybook dev -p 6006 & npm run build.watch",
    "storybook.watch-no-cache": "npm run storybook.clear-cache && npm run build.watch-no-cache & storybook dev -p 6006",
    "test": "npm run test.e2e -- --no-build --maxWorkers=2",
    "test.e2e": "stencil test --spec --e2e",
    "test.e2e.watch": "stencil test --spec --e2e --watchAll",
    "update:fouc": "tsx --tsconfig script.tsconfig.json ./scripts/update-fouc.ts",
    "watch": "npm run build.icons && stencil build --docs-readme --watch",
    "dev": "npm run clean && npm run build.icons && stencil build -c stencil.dev.config.ts --docs-readme --watch"
  },
  "dependencies": {
    "@floating-ui/dom": "1.6.12",
    "@maggioli-design-system/design-tokens": "14.1.0",
    "@maggioli-design-system/styles": "16.0.1",
    "@stencil/core": "4.43.5",
    "clsx": "2.1.0",
    "crypto-js": "4.2.0",
    "dayjs": "1.11.13",
    "filesize": "10.1.0",
    "fitty": "2.4.2",
    "gsap": "3.13.0",
    "idb-keyval": "6.2.1",
    "luxon": "3.6.1",
    "mime": "4.0.4",
    "mustache": "4.2.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "7.23.2",
    "@babel/plugin-syntax-jsx": "7.22.5",
    "@babel/preset-env": "7.23.2",
    "@babel/preset-react": "7.22.15",
    "@babel/preset-typescript": "7.23.2",
    "@iconsauce/core": "1.5.0",
    "@maggioli-design-system/svg-icons": "4.4.0",
    "@rollup/plugin-alias": "5.1.0",
    "@stencil/angular-output-target": "1.3.2",
    "@stencil/eslint-plugin": "1.3.1",
    "@stencil/react-output-target": "1.5.3",
    "@storybook/addon-a11y": "9.0.15",
    "@storybook/addon-docs": "9.0.15",
    "@storybook/addon-links": "9.0.15",
    "@storybook/addon-styling-webpack": "2.0.0",
    "@storybook/addon-webpack5-compiler-babel": "3.0.6",
    "@storybook/react-webpack5": "9.0.15",
    "@storybook/storybook-deployer": "2.8.16",
    "@tailwindcss/postcss": "4.3.0",
    "@types/autoprefixer": "10.2.4",
    "@types/crypto-js": "4.2.1",
    "@types/fs-extra": "11.0.4",
    "@types/lodash": "4.17.16",
    "@types/mustache": "4.2.0",
    "autoprefixer": "10.4.20",
    "babel-loader": "9.1.3",
    "chalk": "4.1.1",
    "css-loader": "6.8.1",
    "cssnano": "7.0.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-storybook": "9.0.15",
    "fs-extra": "11.1.1",
    "handlebars": "4.7.9",
    "jest-environment-node": "29.7.0",
    "jest-transformer-svg": "2.0.2",
    "lodash": "4.18.1",
    "p-queue": "6.6.2",
    "postcss": "8.5.13",
    "postcss-combine-duplicated-selectors": "poimen/postcss-combine-duplicated-selectors#duplicated-keyframes-fix",
    "postcss-combine-media-query": "1.0.1",
    "postcss-discard-comments": "7.0.3",
    "postcss-iconsauce": "1.4.1",
    "postcss-import": "16.1.1",
    "postcss-load-config": "6.0.1",
    "postcss-loader": "8.2.1",
    "postcss-mixins": "12.1.2",
    "puppeteer": "24.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sass-loader": "12.4.0",
    "stdio": "2.1.1",
    "stencil-inline-svg": "1.1.0",
    "storybook": "9.0.15",
    "style-loader": "3.3.3",
    "tailwindcss": "4.3.0",
    "ts-loader": "9.5.0",
    "tsconfig-paths-webpack-plugin": "4.1.0",
    "typescript": "5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magma-design-system/magma.git",
    "directory": "projects/stencil"
  },
  "author": {
    "name": "Vittorio Vittori",
