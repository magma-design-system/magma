{
  "name": "@maggioli-design-system/magma",
  "version": "1.10.2",
  "description": "Magma is Maggioli Design System's web-components library.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mds-components/mds-components.esm.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "npm run clean && npm run build.icons && stencil build --prerender --docs-readme --docs-json dist/documentation.json && npm run publish.isolate.docs-json",
    "build.icons": "iconsauce --verbose --config ./.storybook/iconsauce.config.js --output-dictionary ./src/fixtures/icons.json --output-svg ./assets/svg",
    "build.no-cache": "stencil build --no-cache",
    "build.watch": "npm run build.icons && stencil build --watch",
    "build.watch-no-cache": "stencil build --no-cache --watch",
    "clean": "tsx ./scripts/clean.ts",
    "generate": "stencil generate",
    "generate.doc": "tsx ./scripts/generate-doc.ts",
    "gitlab-ci-yml-regenerate": "tsx ./scripts/gitlab-ci-yml-regenerate.ts",
    "lint": "npm run lint.ts && npm run lint.css",
    "lint.css": "stylelint -c ./stylelint.config.mjs  'src/**/*.css'",
    "lint.ts": "eslint --fix",
    "prebuild": "npm run storybook.version",
    "publish.isolate.all": "npm run publish.isolate.docs-json && tsx ./scripts/isolate-all.ts",
    "publish.isolate.component": "npm run publish.isolate.docs-json && tsx ./scripts/isolate-component.ts",
    "publish.isolate.docs-json": "tsx ./scripts/isolate-docs-json.ts",
    "start": "npm run storybook.clear-cache && npm run storybook.version && storybook dev -p 6006",
    "storybook.build": "npm run storybook.version && storybook build -o ./dist-storybook",
    "storybook.clear-cache": "tsx ./scripts/clean-storybook.ts",
    "storybook.start": "npm run storybook.clear-cache && npm run build.icons && npm run storybook.version && storybook dev -p 6006 & npm run build.watch",
    "storybook.version": "tsx ./scripts/list-components-version.ts",
    "storybook.watch-no-cache": "npm run storybook.clear-cache && npm run build.watch-no-cache & npm run storybook.version && storybook dev -p 6006",
    "test": "npm run test.e2e -- --no-build --maxWorkers=2",
    "test.e2e": "stencil test --spec --e2e",
    "test.e2e.watch": "stencil test --spec --e2e --watchAll",
    "test.regression.approve": "loki approve",
    "test.regression.clean": "tsx ./scripts/clean-regression.ts",
    "test.regression.reference": "npm run build && loki update --port 6006 --chromeFlags='--wm-window-animations-disabled --headless --disable-gpu --hide-scrollbars' --chromeEnableAnimations=false",
    "test.regression.review": "npm run build && loki test --port 6006 --requireReference --chromeEnableAnimations=false",
    "test.script": "npx jest",
    "update": "tsx ./scripts/update.ts",
    "watch": "npm run build.icons && stencil build --docs-readme --watch",
    "dev": "npm run clean && npm run build.icons && stencil build -c stencil.dev.config.ts --docs-readme --watch"
  },
  "dependencies": {
    "@floating-ui/dom": "1.6.12",
    "@maggioli-design-system/design-tokens": "13.7.1",
    "@maggioli-design-system/styles": "16.0.0",
    "@stencil/core": "4.27.2",
    "clsx": "2.1.0",
    "crypto-js": "4.2.0",
    "dayjs": "1.11.13",
    "filesize": "10.1.0",
    "fitty": "2.4.2",
    "gsap": "3.13.0",
    "idb-keyval": "6.2.1",
    "luxon": "3.6.1",
    "mime": "4.0.4",
    "mustache": "4.2.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "7.23.2",
    "@babel/plugin-syntax-jsx": "7.22.5",
    "@babel/preset-env": "7.23.2",
    "@babel/preset-react": "7.22.15",
    "@babel/preset-typescript": "7.23.2",
    "@maggioli-design-system/svg-icons": "4.0.1",
    "@rollup/plugin-alias": "5.1.0",
    "@stencil/angular-output-target": "0.10.2",
    "@stencil/eslint-plugin": "1.1.0",
    "@stencil/react-output-target": "1.0.2",
    "@storybook/addon-a11y": "9.0.15",
    "@storybook/addon-docs": "9.0.15",
    "@storybook/addon-links": "9.0.15",
    "@storybook/addon-styling-webpack": "2.0.0",
    "@storybook/addon-webpack5-compiler-babel": "3.0.6",
    "@storybook/react-webpack5": "9.0.15",
    "@storybook/storybook-deployer": "2.8.16",
    "@tailwindcss/postcss": "4.1.11",
    "stencil-tailwind-plugin": "2.0.5",
    "@types/autoprefixer": "10.2.4",
    "@types/crypto-js": "4.2.1",
    "autoprefixer": "10.4.20",
    "babel-loader": "9.1.3",
    "chalk": "4.1.1",
    "css-loader": "6.8.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-storybook": "9.0.15",
    "handlebars": "4.7.8",
    "jest-environment-node": "29.7.0",
    "jest-transformer-svg": "2.0.2",
    "postcss": "8.4.49",
    "postcss-iconsauce": "1.4.1",
    "postcss-import": "16.0.0",
    "postcss-loader": "7.3.4",
    "puppeteer": "24.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sass-loader": "12.4.0",
    "stdio": "2.1.1",
    "stencil-inline-svg": "1.1.0",
    "storybook": "9.0.15",
    "style-loader": "3.3.3",
    "tailwindcss": "4.1.11",
    "ts-loader": "9.5.0",
    "tsconfig-paths-webpack-plugin": "4.1.0"
  },
  "author": {
    "name": "Vittorio Vittori",
    "email": "vittorio.vittori@maggioli.it",
    "url": "https://vitto.github.io/vit.to/"
  },
