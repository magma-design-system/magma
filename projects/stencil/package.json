{
  "name": "@maggioli-design-system/magma",
  "version": "1.0.0",
  "description": "Magma is Maggioli Design System's web-components library.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/mds-components/mds-components.esm.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "npm run clean && npm run build.fixtures && npm run build.icons && stencil build --prerender --docs-readme --docs-json dist/documentation.json && npm run publish.isolate.docs-json",
    "build.fixtures": "npm run build.icons.prepare && npx ts-node --skipProject ./scripts/fixtures.ts",
    "build.icons": "iconsauce --verbose --config ./.storybook/iconsauce.config.js --output-dictionary ./src/fixtures/icons.json --output-svg ./assets/svg",
    "build.icons.prepare": "nx run svg-icons:dictionary",
    "build.watch": "npm run build.fixtures && npm run build.icons && stencil build --watch",
    "build.watch-no-cache": "stencil build --no-cache --watch",
    "clean": "npx ts-node --skipProject ./scripts/clean.ts",
    "generate": "stencil generate",
    "generate.doc": "npx ts-node --skipProject ./scripts/generate-doc.ts",
    "gitlab-ci-yml-regenerate": "npx ts-node --skipProject ./scripts/gitlab-ci-yml-regenerate.ts",
    "lint": "npm run lint.ts && npm run lint.css",
    "lint.css": "stylelint --config ./.stylelintrc.json 'src/**/*.css'",
    "lint.ts": "eslint --config ./.eslintrc.js src/**/*.{ts,tsx}",
    "prebuild": "npm run storybook.version",
    "publish.isolate.all": "npx ts-node --skipProject ./scripts/isolate-all.ts",
    "publish.isolate.component": "npm run publish.isolate.docs-json && npx ts-node --skipProject ./scripts/isolate-component.ts",
    "publish.isolate.docs-json": "npx ts-node --skipProject ./scripts/isolate-docs-json.ts",
    "storybook.build": "npm run storybook.version && npm run build.icons.prepare && storybook build -o ./dist-storybook",
    "storybook.clear-cache": "npx ts-node --skipProject ./scripts/clean-storybook.ts",
    "storybook.start": "npm run storybook.clear-cache && npm run build.fixtures && npm run build.icons && npm run storybook.version && storybook dev -p 6006 & npm run build.watch",
    "storybook.start-no-cache": "npm run storybook.clear-cache && npm run build.watch-no-cache & npm run storybook.version && storybook dev -p 6006",
    "storybook.version": "npx ts-node --skipProject ./scripts/list-components-version.ts",
    "test": "npm run test.e2e -- --maxWorkers=2",
    "test.e2e": "stencil test --spec --e2e",
    "test.e2e.watch": "stencil test --spec --e2e --watchAll",
    "test.regression.approve": "loki approve",
    "test.regression.clean": "npx ts-node --skipProject ./scripts/clean-regression.ts",
    "test.regression.reference": "npm run build && loki update --port 6006 --chromeFlags='--wm-window-animations-disabled --headless --disable-gpu --hide-scrollbars' --chromeEnableAnimations=false",
    "test.regression.review": "npm run build && loki test --port 6006 --requireReference --chromeEnableAnimations=false",
    "update.dependencies": "npx ts-node --skipProject ./scripts/update-dependencies.ts",
    "update.version": "npx ts-node --skipProject ./scripts/update-version.ts"
  },
  "dependencies": {
    "@floating-ui/dom": "1.5.4",
    "@maggioli-design-system/design-tokens": "12.0.1",
    "@maggioli-design-system/identity": "2.0.4",
    "@maggioli-design-system/styles": "14.2.2",
    "@stencil/core": "4.10.0",
    "clsx": "2.1.0",
    "crypto-js": "4.2.0",
    "filesize": "10.1.0",
    "fitty": "2.4.2",
    "idb-keyval": "6.2.1",
    "mime": "4.0.1"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "7.23.2",
    "@babel/plugin-syntax-jsx": "7.22.5",
    "@babel/preset-env": "7.23.2",
    "@babel/preset-react": "7.22.15",
    "@babel/preset-typescript": "7.23.2",
    "@rollup/plugin-alias": "5.1.0",
    "@stencil/eslint-plugin": "0.4.0",
    "@stencil/postcss": "2.1.0",
    "@storybook/addon-actions": "7.6.7",
    "@storybook/addon-essentials": "7.6.7",
    "@storybook/addon-styling": "1.3.7",
    "@storybook/addon-viewport": "7.6.7",
    "@storybook/manager-api": "7.6.7",
    "@storybook/react": "7.6.7",
    "@storybook/react-webpack5": "7.6.7",
    "@storybook/storybook-deployer": "2.8.16",
    "@types/crypto-js": "4.2.1",
    "@types/prompt": "1.1.7",
    "@types/tapable": "2.2.5",
    "autoprefixer": "10.4.16",
    "babel-loader": "9.1.3",
    "css-loader": "6.8.1",
    "directory-tree": "3.5.1",
    "eslint-plugin-storybook": "0.6.15",
    "handlebars": "4.7.8",
    "jest-transformer-svg": "1.0.2",
    "postcss": "8.4.33",
    "postcss-flexbugs-fixes": "5.0.2",
    "postcss-iconsauce": "1.4.1",
    "postcss-import": "16.0.0",
    "postcss-loader": "7.3.4",
    "prettier": "3.1.1",
    "prettier-plugin-tailwindcss": "0.5.6",
    "prompt": "1.3.0",
    "puppeteer": "21.3.8",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rimraf": "5.0.5",
    "sass-loader": "12.4.0",
    "stdio": "2.1.1",
    "stencil-inline-svg": "1.1.0",
    "storybook": "7.6.7",
    "style-loader": "3.3.3",
    "tailwindcss": "3.4.1",
    "ts-loader": "9.5.0",
    "tsconfig-paths-jest": "0.0.1",
    "tsconfig-paths-webpack-plugin": "4.1.0"
  },
  "author": {
    "name": "Vittorio Vittori",
    "email": "vittorio.vittori@maggioli.it",
    "url": "https://vitto.github.io/vit.to/"
  },
  "contributors": [
