{
  "name": "stencil-components",
  "version": "0.23.0",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/custom-elements/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/custom-elements/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/stencil-components/stencil-components.esm.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "build.full": "rm src/components.d.ts || true && stencil build --docs --docs-readme",
    "build.watch": "stencil build --watch",
    "clean": "rimraf dist && rimraf loader && rimraf www && rimraf dist-storybook",
    "generate": "stencil generate",
    "lint": "npm run lint-ts && npm run lint-css",
    "lint-css": "stylelint --config ../../.stylelintrc.json 'src/**/*.css' --fix",
    "lint-ts": "eslint src/**/*.{ts,tsx} --fix",
    "start": "stencil build --dev --watch --serve",
    "storybook.build": "build-storybook -o ./dist-storybook",
    "storybook.deploy": "storybook-to-aws-s3 --existing-output-dir ./dist-storybook --bucket-path <AWS_BUCKET_PATH>",
    "storybook.prebuild": "npm run build-stencil",
    "storybook.predeploy": "npm run build-storybook",
    "storybook.start": "start-storybook -p 6006 -s ./dist,./assets --no-manager-cache",
    "test": "stencil test --spec --e2e",
    "test.watch": "stencil test --spec --e2e --watchAll"
  },
  "dependencies": {
    "@maggioli-design-system/design-tokens": "^4.2.0",
    "@maggioli-design-system/icons": "^1.16.0",
    "@maggioli-design-system/identity": "^1.8.3",
    "@maggioli-design-system/styles": "^3.8.3",
    "@stencil/core": "^2.6.0",
    "@stencil/state-tunnel": "^1.0.1"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.14.6",
    "@babel/preset-react": "^7.14.5",
    "@stencil/eslint-plugin": "0.3.1",
    "@stencil/postcss": "2.0.0",
    "@storybook/addon-actions": "^6.3.2",
    "@storybook/addon-essentials": "^6.3.2",
    "@storybook/addon-links": "^6.3.2",
    "@storybook/addon-notes": "^5.3.21",
    "@storybook/addon-postcss": "^2.0.0",
    "@storybook/addon-viewport": "^6.3.2",
    "@storybook/html": "^6.3.2",
    "@storybook/manager-webpack5": "^6.3.2",
    "@storybook/react": "^6.3.2",
    "@storybook/storybook-deployer": "^2.8.10",
    "@types/jest": "^26.0.23",
    "@types/tapable": "^2.2.2",
    "autoprefixer": "^10.2.6",
    "babel-loader": "^8.2.2",
    "clsx": "^1.1.1",
    "css-loader": "^5.2.6",
    "faker": "^5.5.3",
    "postcss": "^8.3.5",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "14.0.2",
    "postcss-loader": "^6.1.0",
    "rimraf": "^3.0.2",
    "sass-loader": "12.1.0",
    "style-loader": "^3.0.0",
    "tailwindcss": "2.2.6"
  },
  "author": {
    "name": "Vittorio Vittori",
    "email": "vittorio.vittori@maggioli.it",
    "url": "http://vit.to"
  },
  "contributors": [
    {
      "name": "Andrea Pruccoli",
      "email": "andrea.pruccoli@maggioli.it",
      "role": "Software Engineer"
    },
    {
      "name": "Stefano Pascazi",
      "email": "stefano.pascazi@maggioli.it",
      "role": "Software Engineer"
    },
    {
      "name": "Vittorio Vittori",
      "email": "vittorio.vittori@maggioli.it",
      "role": "UX UI Designer"
    }
  ]
}
