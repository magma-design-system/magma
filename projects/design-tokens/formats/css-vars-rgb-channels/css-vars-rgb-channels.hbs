@layer vars {

  :root {
    {{#each properties as | groups |}}
      {{#each groups as | names |}}
        {{#each names as | lightModes |}}
          {{#each lightModes as | palettes |}}
            {{#ifEquals @key 'light'}}
              {{#each palettes as | palette |}}
                {{#ifEquals @key 'color'}}
    --{{@../../../key}}-{{@../../key}}: {{rgbChannel palette.value}};
                {{else}}
    --{{@../../../key}}-{{@../../key}}-{{leadZero @key}}: {{rgbChannel palette.value}};
                {{/ifEquals}}
              {{/each}}
            {{/ifEquals}}
            {{/each}}
        {{/each}}
      {{/each}}
    {{/each}}
  }

  @media (prefers-color-scheme: dark) {
    :root {
      {{#each properties as | groups |}}
        {{#each groups as | names |}}
          {{#each names as | lightModes |}}
            {{#each lightModes as | palettes |}}
              {{#ifEquals @key 'dark'}}
                {{#each palettes as | palette |}}
                  {{#ifEquals @key 'color'}}
      --{{@../../../key}}-{{@../../key}}: {{rgbChannel palette.value}};
                  {{else}}
      --{{@../../../key}}-{{@../../key}}-{{leadZero @key}}: {{rgbChannel palette.value}};
                  {{/ifEquals}}
                {{/each}}
              {{/ifEquals}}
              {{/each}}
          {{/each}}
        {{/each}}
      {{/each}}
    }
  }

}
