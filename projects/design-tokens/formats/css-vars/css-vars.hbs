          {{#ifEquals @key 'light'}}
            {{#each palettes as | palette |}}
              {{#ifEquals @key 'color'}}
  --{{@../../../key}}-{{@../../key}}: {{palette.value}};
              {{else}}
  --{{@../../../key}}-{{@../../key}}-{{@key}}: {{palette.value}};
              {{/ifEquals}}
            {{/each}}
          {{/ifEquals}}
          {{/each}}
      {{/each}}
    {{/each}}
  {{/each}}
}

