{
  "source": [
    "properties/font/default.json"
  ],
  "platforms": {
    "js": {
      "transformGroup": "js",
      "buildPath": "dist/js/",
      "files": [
        {
          "destination": "tailwind-font-family.js",
          "format": "js/tailwind-font-family"
        },{
          "destination": "tailwind-font-size.js",
          "format": "js/tailwind-font-size"
        }
      ]
    },
    "flutter": {
      "transforms": [
        "attribute/cti",
        "name/cti/camel",
        "content/flutter/literal",
        "asset/flutter/literal",
        "font/flutter/literal",
        "flutter/ToDouble",
        "flutter/fontWeight"
      ],
      "buildPath": "dist/flutter/",
      "files": [
        {
          "destination": "fonts.dart",
          "format": "flutter/font"
        }
      ]
    }
  }
}
