{
  "source": [
    "properties/font/*.json"
  ],
  "platforms": {
    "js": {
      "transformGroup": "js",
      "buildPath": "dist/js/",
      "files": [
        {
          "destination": "tailwind-font-family.js",
          "format": "js/tailwind-font-family"
        },{
          "destination": "tailwind-font-size.js",
          "format": "js/tailwind-font-size"
        }
      ]
    },
    "flutter": {
      "transformGroup": "flutter",
      "buildPath": "dist/flutter/",
      "files": [
        {
          "destination": "flutter-font.dart",
          "format": "flutter/font"
        }
      ]
    }
  }
}
