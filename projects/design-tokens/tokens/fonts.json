{
  "title": {
    "fontFamily": [
      "Roboto",
      "-apple-system",
      "BlinkMacSystemFont",
      "'San Francisco'",
      "'Segoe UI'",
      "'Helvetica Neue'",
      "sans-serif"
    ],
    "variants": {
      "h1": {
        "properties": {
          "fontSize": "48px",
          "fontWeight": 900,
          "letterSpacing": "-0.4px",
          "lineHeight": "48px"
        },
        "media": {
          "mobile": {
            "fontSize": "42px",
            "lineHeight": "42px"
          }
        }
      },
      "h2": {
        "properties": {
          "fontSize": "36px",
          "fontWeight": 900,
          "letterSpacing": "-0.4px",
          "lineHeight": "40px"
        }
      },
      "h3": {
        "properties": {
          "fontSize": "30px",
          "fontWeight": 900,
          "letterSpacing": "-0.4px",
          "lineHeight": "36px"
        }
      },
      "h4": {
        "properties": {
          "fontSize": "24px",
          "fontWeight": 700,
          "letterSpacing": "-0.4px",
          "lineHeight": "32px"
        }
      },
      "h5": {
        "properties": {
          "fontSize": "20px",
          "fontWeight": 700,
          "letterSpacing": "-0.4px",
          "lineHeight": "28px"
        }
      },
      "h6": {
        "properties": {
          "fontSize": "16px",
          "fontWeight": 700,
          "letterSpacing": "-0.4px",
          "lineHeight": "24px"
        }
      },
      "action": {
        "properties": {
          "fontSize": "14px",
          "fontWeight": 500,
          "lineHeight": "24px"
        }
      }
    }
  },
  "info": {
    "fontFamily": [
      "Karla",
      "-apple-system",
      "BlinkMacSystemFont",
      "'San Francisco'",
      "'Segoe UI'",
      "'Helvetica Neue'",
      "sans-serif"
    ],
    "variants": {
      "paragraph": {
        "properties": {
          "fontSize": "20px",
          "fontWeight": 400,
          "lineHeight": "28px"
        }
      },
      "detail": {
        "properties": {
          "fontSize": "16px",
          "fontWeight": 400,
          "lineHeight": "24px"
        }
      },
      "caption": {
        "properties": {
          "fontSize": "14px",
          "fontWeight": 400,
          "lineHeight": "20px"
        }
      },
      "label": {
        "properties": {
          "fontSize": "12px",
          "fontWeight": 700,
          "lineHeight": "16px",
          "textTransform": "uppercase"
        }
      },
      "option": {
        "properties": {
          "fontSize": "10px",
          "fontWeight": 700,
          "letterSpacing": "-0.4px",
          "lineHeight": "10px",
          "textTransform": "uppercase"
        }
      },
      "tip": {
        "properties": {
          "fontSize": "12px",
          "fontWeight": 400,
          "letterSpacing": "-0.4px",
          "lineHeight": "16px"
        }
      }
    }
  },
  "read": {
    "fontFamily": [
      "'Merriweather'",
      "Times",
      "'Times New Roman'",
      "serif"
    ],
    "variants": {
      "paragraph": {
        "fontSize": "20px",
        "fontWeight": 300,
        "lineHeight": "32px"
      },
      "detail": {
        "properties": {
          "fontSize": "16px",
          "fontWeight": 300,
          "lineHeight": "24px"
        }
      },
      "caption": {
        "properties": {
          "fontSize": "14px",
          "fontWeight": 400,
          "lineHeight": "20px"
        }
      }
    }
  },
  "code": {
    "fontFamily": [
      "'Roboto Mono'",
      "monospace"
    ],
    "variants": {
      "snippet": {
        "properties": {
          "fontSize": "16px",
          "fontWeight": 400,
          "lineHeight": "24px"
        }
      },
      "hack": {
        "properties": {
          "fontSize": "14px",
          "fontWeight": 400,
          "lineHeight": "24px"
        }
      }
    }
  }
}
