{
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react",
    "baseUrl": ".",
    "lib": ["esnext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "resolveJsonModule": true,
    "sourceMap": true,
    "target": "es2017",
    "paths": {
      "@/formats/*": ["src/formats/*"],
    }
  },
  "include": ["src", "src/formats"],
  "exclude": ["node_modules", "test"]
}
