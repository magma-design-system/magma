{
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,
    "jsx": "react",
    "baseUrl": ".",
    "lib": ["esnext"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "sourceMap": false,
    "target": "ESNext",
    "paths": {
      "@/formats/*": ["src/formats/*"],
      "@/leonardo/*": ["src/lib/leonardo/*"],
    },
  },
  "include": ["src", "test"],
  "exclude": ["node_modules" ]
}
