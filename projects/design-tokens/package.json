{
  "name": "@maggioli-design-system/design-tokens",
  "version": "6.1.0",
  "description": "This is the Design Token library of Maggioli Design System, here you'll find all the visual data used around the libraries.",
  "author": "Vittorio Vittori",
  "contributors": [
    {
      "name": "Vittorio Vittori",
      "email": "vittorio.vittori@maggioli.it",
      "role": "UX UI Designer"
    }
  ],
  "license": "ISC",
  "scripts": {
    "build": "npm run clean || true && npm run build-palette && npm run build-style-dictionary && npm run build-css-tokens",
    "build-css-tokens": "run-for-every-file --src ./css-tokens/ --dest dist/scss/ --file '**/*.json' --not-file '**/*.scss' --run 'json-to-scss {{src-file}} {{dest}}{{file-name-ext}}'",
    "build-palette": "node leonardo.mjs",
    "build-style-dictionary": "node build.js",
    "clean": "rm -rf dist",
    "postbuild": "cp -rf properties ./dist/properties && cp -rf css-tokens ./dist/css-tokens"
  },
  "main": "dist/js/tailwind-colors-css-vars.js",
  "files": [
    "/dist/*"
  ],
  "devDependencies": {
    "@adobe/leonardo-contrast-colors": "1.0.0-alpha.12",
    "handlebars": "^4.7.7",
    "hex-rgb": "^4.3.0",
    "js-beautify": "1.14.0",
    "json-to-scss": "^1.6.2",
    "run-for-every-file": "^1.1.0",
    "style-dictionary": "^3.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
  },
  "keywords": [
    "amazon",
    "data-driven",
    "design-token",
    "json",
    "platform-agnostic",
    "style-dictionary"
  ]
}
