{
  "name": "@maggioli-design-system/design-tokens",
  "version": "0.1.0",
  "description": "This example code is bare-bones to show you what this framework can do. If you have the style-dictionary module installed globally, you can `cd` into this directory and run: ```bash style-dictionary build ```",
  "author": "Vittorio Vittori",
  "license": "ISC",
  "main": "build.js",
  "publishConfig": {
    "registry": "http://nexus.maggioli.it:8081/repository/npm/"
  },
  "scripts": {
    "build": "npm run build-palette && npm run build-style-dictionary && npm run build-css-tokens && npm run build-css-tokens-config",
    "build-css-tokens": "run-for-every-file --src ./css-tokens/ --dest dist/scss/ --file '**/*.json' --not-file '**/*.scss' --run 'json-to-scss {{src-file}} {{dest}}{{file-name-ext}}'",
    "build-css-tokens-config": "json-to-scss --v=sq --s='!default;' ./css-tokens/config.json dist/scss/config.scss",
    "build-palette": "node leonardo.mjs",
    "build-style-dictionary": "node build.js",
    "postbuild": "cp -rf properties ./dist/properties && cp -rf css-tokens ./dist/css-tokens"
  },
  "files": [
    "/dist/*"
  ],
  "dependencies": {},
  "devDependencies": {
    "@adobe/leonardo-contrast-colors": "1.0.0-alpha.8",
    "handlebars": "^4.7.6",
    "json-to-scss": "^1.6.2",
    "run-for-every-file": "^1.1.0",
    "style-dictionary": "^2.10.2"
  },
  "repository": {
    "type": "git",
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
  },
  "keywords": [
    "amazon",
    "data-driven",
    "design-token",
    "json",
    "platform-agnostic",
    "style-dictionary"
  ]
}
