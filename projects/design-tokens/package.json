{
  "name": "@maggioli-design-system/design-tokens",
  "version": "11.0.1",
  "description": "This is the Design Token library of Maggioli Design System, here you'll find all the visual data used around the libraries.",
  "author": "Vittorio Vittori",
  "contributors": [
    {
      "name": "Vittorio Vittori",
      "email": "vittorio.vittori@maggioli.it",
      "role": "UX UI Designer"
    },
    {
      "name": "Daniele Tardia",
      "email": "daniele.tardia@hibo.it",
      "role": "Senior Developer"
    }
  ],
  "license": "ISC",
  "scripts": {
    "build": "npm run clean && npm run build-palette && npm run build-style-dictionary && npm run build-figma-tokens && npm run build-css-tokens",
    "build-css-tokens": "run-for-every-file --src ./tokens/css/ --dest dist/scss/ --file '**/*.json' --not-file '**/*.scss' --run 'json-to-scss {{src-file}} {{dest}}{{file-name-ext}}'",
    "build-palette": "node leonardo.mjs",
    "build-figma-tokens": "npx ts-node scripts/generate-figma-tokens.ts",
    "build-style-dictionary": "npx ts-node scripts/build.ts",
    "clean": "npx ts-node scripts/clean.ts",
    "postbuild": "npx ts-node scripts/postbuild.ts"
  },
  "main": "dist/js/tailwind-colors-css-vars.js",
  "files": [
    "/dist/"
  ],
  "devDependencies": {
    "@adobe/leonardo-contrast-colors": "1.0.0-alpha.13",
    "handlebars": "4.7.8",
    "hex-rgb": "4.3.0",
    "js-beautify": "1.14.3",
    "json-to-scss": "1.6.2",
    "run-for-every-file": "1.1.0",
    "style-dictionary": "3.8.0"
  },
  "repository": {
    "type": "git",
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
  },
  "keywords": [
    "amazon",
    "data-driven",
    "design-token",
    "json",
    "platform-agnostic",
    "style-dictionary"
  ]
}
