{
  "source": [
    "properties/color/{{fileName}}.json"
  ],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "dist/css/",
      "files": [
        {
          "format": "css/vars",
          "destination": "colors-hex-{{fileName}}.css"
        },
        {
          "format": "css/vars-rgb-channels",
          "destination": "colors-rgb-{{fileName}}.css"
        }
      ]
    },
    "dart": {
      "transformGroup": "js",
      "buildPath": "dist/dart/",
      "files": [
        {
          "destination": "colors-{{fileName}}.dart",
          "format": "dart/colors"
        }
      ]
    }
  }
}
