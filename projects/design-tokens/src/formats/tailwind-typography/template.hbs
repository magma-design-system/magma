/*
@magma-design-system/design-tokens v{{ version }}
Generated by Style Dictionary
Do not edit directly
Generated at {{ date }}
*/

@theme {
{{!-- font family --}}
{{#each properties as | fonts |}}
  {{#each fonts as | groups |}}
    {{#if groups.fontFamily.value }}
  --font-{{@key}}: {{#each groups.fontFamily.value}} {{ safeString this }}{{#unless @last}},{{/unless}}{{/each}};
    {{/if}}
  {{/each}}
{{/each}}

{{!-- fontsize --}}
{{#each properties as | fonts |}}
  {{#each fonts as | groups |}}
    {{#each groups.variants as | variants |}}
  --text-size-{{@../key}}-{{@key}}: {{#tailwindFontSize 'fontSize' variants.fontSize.value}}{{/tailwindFontSize}};
      {{#each variants as | rules |}}
        {{#ifTailwindFontSizeProp @key}}
  --text-size-{{@../../key}}-{{@../key}}--{{#kebabCase}}{{@key}}{{/kebabCase}}: {{#tailwindFontSize @key rules.value}}{{/tailwindFontSize}};
        {{/ifTailwindFontSizeProp}}
      {{/each}}
    {{/each}}
  {{/each}}
{{/each}}

{{!-- leading --}}
{{#each properties as | property |}}
  {{#each property.leading as | leading |}}
  --leading-{{@key}}: {{#pixelToRem}}{{leading.value}}{{/pixelToRem}};
  {{/each}}
{{/each}}

{{!-- spacing --}}
  --spacing: {{properties.spacing}};

{{!-- container with --}}
{{#each properties.container as | container |}}
  --container-{{@key}}: {{container.value}};
{{/each}}
}


