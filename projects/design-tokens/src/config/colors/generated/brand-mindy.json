{
  "source": [
    "tokens/color/generated/brand-mindy.json"
  ],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "dist/css/",
      "files": [
        {
          "format": "css/vars",
          "destination": "colors-hex-brand-mindy.css"
        },
        {
          "format": "css/vars-rgb-channels",
          "destination": "colors-rgb-brand-mindy.css"
        }
      ]
    },
    "dart": {
      "transformGroup": "js",
      "buildPath": "dist/flutter/",
      "files": [
        {
          "destination": "colors-brand-mindy.dart",
          "format": "flutter/color"
        }
      ]
    }
  }
}
