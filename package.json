{
  "name": "maggioli-design-system",
  "version": "1.0.0",
  "description": "Maggioli Design System è uno strumento nato per condividere una unica visione di progettazione condivisa tra tutti gli esperti di dominio aziendali. Ciò permette di offrire una UX unica, condivisa tra i prodotti che saranno coerenti allo stile dell’azienda.",
  "private": true,
  "workspaces": [
    "projects/!(deprecated)",
    "projects/stencil/react",
    "projects/stencil/angular"
  ],
  "devDependencies": {
    "@commitlint/cli": "17.8.0",
    "@commitlint/config-conventional": "17.8.0",
    "@nx/workspace": "21.1.3",
    "@types/jest": "29.5.14",
    "@typescript-eslint/eslint-plugin": "6.8.0",
    "@typescript-eslint/parser": "6.8.0",
    "chalk": "4.1.1",
    "conventional-changelog": "6.0.0",
    "conventional-changelog-cli": "5.0.0",
    "eslint": "8.51.0",
    "eslint-plugin-react": "7.33.2",
    "fs-extra": "11.1.1",
    "husky": "8.0.3",
    "jest": "29.7.0",
    "jest-cli": "29.7.0",
    "lint-staged": "15.0.1",
    "prettier": "3.0.3",
    "standard": "17.1.0",
    "stylelint": "15.11.0",
    "stylelint-config-recess-order": "4.3.0",
    "stylelint-config-standard": "34.0.0",
    "stylelint-order": "6.0.3",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.1",
    "typescript": "5.2.2"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "changelog.design-tokens": "conventional-changelog -p conventionalcommits -i projects/design-tokens/CHANGELOG.md -s --commit-path projects/design-tokens",
    "changelog.icons": "conventional-changelog -p conventionalcommits -i projects/icons/CHANGELOG.md -s --commit-path projects/icons",
    "changelog.identity": "conventional-changelog -p conventionalcommits -i projects/identity/CHANGELOG.md -s --commit-path projects/identity",
    "changelog.stencil": "conventional-changelog -p conventionalcommits -i projects/stencil/CHANGELOG.md -s --commit-path projects/stencil",
    "changelog.styles": "conventional-changelog -p conventionalcommits -i projects/styles/CHANGELOG.md -s --commit-path projects/styles",
    "changelog.svg-icons": "conventional-changelog -p conventionalcommits -i projects/svg-icons/CHANGELOG.md -s --commit-path projects/svg-icons",
    "clean-modules": "rm -rf node_modules || true && rm -rf projects/**/node_modules || true && rm yarn.lock",
    "prepare": "husky install",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/ricerca-sviluppo-new-media/design-system.git"
  },
