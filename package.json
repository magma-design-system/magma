{
  "name": "@maggioli/design-system",
  "version": "0.0.12",
  "description": "Maggioli Design system",
  "scripts": {
    "setup": "cd projects/mgg-icons && npm install && cd ../font-icons-cli && npm install && cd ../../ && npm install && npm run storybook",
    "build": "run-p 'build:!(storybook)'",
    "build:gatsby": "npm run tokens && gatsby build",
    "build:lib": "npm run tokens && build-storybook -o design-lib",
    "build:storybook": "build-storybook",
    "deploy": "storybook-to-ghpages",
    "storybook-debug": "npm run tokens && start-storybook --debug-webpack -p 7177",
    "storybook": "npm run tokens && start-storybook -p 7177",
    "lint": "npm run lint:js && npm run lint:sass",
    "lint:js": "eslint src/react/**/*.{js,jsx} --fix",
    "lint:sass": "npx stylelint --config .stylelintrc.json 'src/scss/**/*.scss' --fix --ignore-pattern 'src/scss/variables/**/*.scss'",
    "tokens": "npm run tokens:icons && npm run tokens:rebuild-palette && npm run tokens:css-tokens && npm run tokens:css-tokens-config && npm run tokens:style-dictionary",
    "tokens:icons": "cd projects/mgg-icons && npm run build",
    "tokens:rebuild-palette": "cd src/style-dictionary && node leonardo.mjs",
    "tokens:css-tokens": "run-for-every-file --src src/style-dictionary/css-tokens/ --dest src/scss/variables/ --file '**/*.json' --not-file '**/*.scss' --run 'json-to-scss {{src-file}} {{dest}}{{file-name-ext}}'",
    "tokens:css-tokens-config": "json-to-scss --v=sq --s='!default;' src/style-dictionary/css-tokens/config.json src/scss/variables/config.scss",
    "tokens:style-dictionary": "cd ./src/style-dictionary/ && node build.js",
    "start": "run-p start:**",
    "doc": "npm run tokens && npm run clean:gatsby && npm run start:gatsby",
    "start:gatsby": "gatsby develop -H 0.0.0.0 -p 3898 -o",
    "start:storybook": "npm run storybook",
    "serve:gatsby": "gatsby serve -o -p 3898",
    "clean:gatsby": "gatsby clean"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint",
      "pre-push": ""
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "main": "index.js",
  "files": [
    "/src/assets/**/*",
    "/src/react/**/*",
    "/src/scss/**/*",
    "/src/style-dictionary/build/**/*",
    "import-aliases.js"
  ],
  "publishConfig": {
    "registry": "http://nexus.maggioli.it:8081/repository/npm/"
  },
  "repository": {
    "type": "git",
    "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
  },
  "author": {
    "name": "Vittorio Vittori",
    "email": "vittorio.vittori@maggioli.it",
    "url": "http://vit.to"
  },
  "contributors": [
    {
      "name": "Fabion Dautaj",
      "email": "fabion.dautaj@maggioli.it"
    },
    {
      "name": "Federica Turroni",
      "email": "federica.turroni@maggioli.it"
    },
    {
      "name": "Federico Ciani",
      "email": "federico.ciani@maggioli.it"
    },
    {
      "name": "Gioele Masini",
      "email": "gioele.masini@maggioli.it"
    },
    {
      "name": "Matteo Innocenti",
      "email": "matteo.innocenti@maggioli.it"
    },
    {
      "name": "Thomas Trapanese",
      "email": "thomas.trapanese@maggioli.it"
    }
  ],
  "license": "ISC",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^5.14.0",
    "material-design-icons": "^3.0.1",
    "material-design-icons-updated": "^6.1.0",
    "normalize.css": "^8.0.1",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-gsap": "^2.2.1",
    "react-helmet": "^6.1.0",
    "react-router-dom": "^5.2.0",
    "react-syntax-highlighter": "^13.5.3",
    "react-timeago": "^4.4.0",
    "typeface-karla": "0.0.72",
    "typeface-roboto": "0.0.75"
  },
  "devDependencies": {
    "@adobe/leonardo-contrast-colors": "^1.0.0-alpha.7",
    "@babel/core": "^7.11.1",
    "@deckdeckgo/highlight-code": "^2.1.0",
    "@mdx-js/mdx": "^1.6.16",
    "@mdx-js/react": "^1.6.16",
    "@storybook/addon-actions": "^6.0.26",
    "@storybook/addon-docs": "^6.0.26",
    "@storybook/addon-links": "^6.0.26",
    "@storybook/addons": "^6.0.26",
    "@storybook/react": "^6.0.26",
    "autoprefixer": "^9.8.6",
    "babel-cli": "^6.26.0",
    "babel-loader": "^8.1.0",
    "babel-plugin-styled-components": "^1.11.1",
    "babel-preset-es2015": "^6.24.1",
    "concat-files": "^0.1.1",
    "eslint": "^7.7.0",
    "eslint-config-standard": "^14.1.1",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-jsx-a11y": "^6.3.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-react": "^7.20.6",
    "eslint-plugin-standard": "^4.0.1",
    "faker": "^4.1.0",
    "fontello-cli": "^0.5.0",
    "gatsby": "^2.24.47",
    "gatsby-alias-imports": "^1.0.4",
    "gatsby-image": "^2.4.16",
    "gatsby-plugin-manifest": "^2.4.23",
    "gatsby-plugin-mdx": "^1.2.34",
    "gatsby-plugin-offline": "^3.2.23",
    "gatsby-plugin-page-creator": "^2.3.22",
    "gatsby-plugin-react-helmet": "^3.3.10",
    "gatsby-plugin-root-import": "^2.0.5",
    "gatsby-plugin-sass": "^2.3.12",
    "gatsby-plugin-sharp": "^2.6.27",
    "gatsby-plugin-styled-components": "^3.3.10",
    "gatsby-remark-highlight-code": "^2.1.0",
    "gatsby-source-filesystem": "^2.3.24",
    "gatsby-transformer-remark": "^2.8.35",
    "gatsby-transformer-sharp": "^2.5.13",
    "get-contrast": "^2.0.0",
    "handlebars": "^4.7.6",
    "hex-rgb": "^4.1.0",
    "husky": "^4.2.5",
    "json-to-scss": "^1.5.0",
    "node-sass": "^4.14.1",
    "postcss-loader": "^3.0.0",
    "prop-types": "^15.7.2",
    "query-string": "^6.13.2",
    "run-for-every-file": "^1.1.0",
    "run-p": "0.0.0",
    "sass-extract": "^2.1.0",
    "sass-loader": "^8.0.2",
    "standard": "^14.3.4",
    "style-dictionary": "^2.10.1",
    "styled-components": "^5.1.1",
    "styled-reset-advanced": "^1.0.3",
    "stylelint": "^13.6.1",
    "stylelint-config-sass-guidelines": "^7.0.0",
    "stylelint-config-standard": "^20.0.0",
    "stylelint-order": "^4.1.0",
    "stylelint-scss": "^3.18.0"
  }
}
