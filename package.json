{
    "name": "@maggioli/design-system",
    "version": "0.0.60",
    "description": "Maggioli Design system",
    "scripts": {
        "setup": "cd projects/mgg-icons && npm install && cd ../font-icons-cli && npm install && cd ../../ && npm install && npm run storybook",
        "setup:build": "cd projects/mgg-icons && npm install && cd ../font-icons-cli && npm install && cd ../../ && npm install && npm run tokens && npm run build:storybook",
        "build": "run-p 'build:!(storybook)'",
        "build:gatsby": "npm run tokens && gatsby build",
        "build:lib": "npm run tokens && build-storybook -o design-lib",
        "build:storybook": "build-storybook",
        "deploy": "storybook-to-ghpages",
        "storybook-debug": "npm run tokens && start-storybook --debug-webpack -p 7177",
        "storybook": "npm run tokens && start-storybook -p 7177",
        "lint": "npm run lint:js && npm run lint:sass",
        "lint:js": "eslint src/react/**/*.{js,jsx} --fix",
        "lint:sass": "npx stylelint --config .stylelintrc.json 'src/scss/**/*.scss' --fix --ignore-pattern 'src/scss/variables/**/*.scss'",
        "tokens": "npm run tokens:icons && npm run tokens:rebuild-palette && npm run tokens:css-tokens && npm run tokens:css-tokens-config && npm run tokens:style-dictionary",
        "tokens:icons": "cd projects/mgg-icons && npm run build",
        "tokens:rebuild-palette": "cd src/style-dictionary && node leonardo.mjs",
        "tokens:css-tokens": "run-for-every-file --src src/style-dictionary/css-tokens/ --dest src/scss/variables/ --file '**/*.json' --not-file '**/*.scss' --run 'json-to-scss {{src-file}} {{dest}}{{file-name-ext}}'",
        "tokens:css-tokens-config": "json-to-scss --v=sq --s='!default;' src/style-dictionary/css-tokens/config.json src/scss/variables/config.scss",
        "tokens:style-dictionary": "cd ./src/style-dictionary/ && node build.js",
        "start": "run-p start:**",
        "doc": "npm run tokens && npm run clean:gatsby && npm run start:gatsby",
        "start:gatsby": "gatsby develop -H 0.0.0.0 -p 3898 -o",
        "start:storybook": "npm run storybook",
        "serve:gatsby": "gatsby serve -o -p 3898",
        "clean:gatsby": "gatsby clean",
        "build:react": "webpack --config webpack.config.js"
    },
    "husky": {
        "hooks": {
            "pre-commit": "npm run lint",
            "pre-push": ""
        }
    },
    "browserslist": [
        "> 1%",
        "last 2 versions"
    ],
    "main": "dist/bundle.min.js",
    "files": [
        "/src/scss/**/*",
        "/src/style-dictionary/build/**/*",
        "/import-aliases.js",
        "/dist/**/*"
    ],
    "publishConfig": {
        "registry": "http://nexus.maggioli.it:8081/repository/npm/"
    },
    "repository": {
        "type": "git",
        "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system.git"
    },
    "bugs": {
        "url": "https://git.maggioli.it/ricerca-sviluppo-new-media/design-system/-/issues"
    },
    "author": {
